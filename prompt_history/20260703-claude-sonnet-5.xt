python3 -c "
import json
d = json.load(open('/tmp/akira-schedule-current.json'))
target = d['Target']
target['TaskDefinitionArn'] = target['EcsParameters']['TaskDefinitionArn'].rsplit(':',1)[0] + ':3' if 'EcsParameters' in target else target
target['EcsParameters']['TaskDefinitionArn'] = 'arn:aws:ecs:us-east-1:210387976006:task-definition/akira-daily:3'
json.dump(target, open('/tmp/akira-schedule-target-new.json','w'), indent=2)
print(json.dumps(target['EcsParameters'], indent=1))
"

