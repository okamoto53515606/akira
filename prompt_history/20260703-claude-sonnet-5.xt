Now register a new task definition revision adding `DEBUG_TOOL_LOGGING=true`, then point the scheduler at it:  

Ran terminal command:  export AWS_PROFILE=okamo AWS_REGION=us-east-1
python3 -c "
import json
d = json.load(open('/tmp/akira-current-taskdef.json'))
envs = d['containerDefinitions'][0]['environment']
if not any(e['name']=='DEBUG_TOOL_LOGGING' for e in envs):
    envs.append({'name': 'DEBUG_TOOL_LOGGING', 'value': 'true'})
newdef = {
    'family': d['family'],
    'networkMode': d['networkMode'],
    'requiresCompatibilities': d['requiresCompatibilities'],
    'cpu': d['cpu'],
    'memory': d['memory'],
    'executionRoleArn': d['executionRoleArn'],
    'taskRoleArn': d['taskRoleArn'],
    'runtimePlatform': d['runtimePlatform'],
    'containerDefinitions': d['containerDefinitions'],
}
json.dump(newdef, open('/tmp/akira-taskdef-new.json','w'), indent=2)
print('prepared')
"
cat /tmp/akira-taskdef-new.json | python3 -c "import json,sys; d=json.load(sys.stdin); print([e for e in d['containerDefinitions'][0]['environment']])"

Ran terminal command:  export AWS_PROFILE=okamo AWS_REGION=us-east-1
aws ecs register-task-definition --cli-input-json file:///tmp/akira-taskdef-new.json --region us-east-1 --query "taskDefinition.{arn:taskDefinitionArn,rev:revision}" --output json

Now update the EventBridge Scheduler target to the new revision:  

Ran terminal command:  export AWS_PROFILE=okamo AWS_REGION=us-east-1
