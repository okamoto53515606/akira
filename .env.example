# Akira ローカル実行用の環境変数サンプル
# 実際の値は .env にコピーして設定してください（.env は .gitignore 済み・コミット禁止）
# AWS_PROFILE や GitHub PAT などローカル専用の値はこのサンプルには含めていません。

GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
BRAVE_API_KEY=""

AWS_REGION="us-east-1"

BEDROCK_MODEL_ID=""
GEMINI_MODEL_ID="gemini-3.5-flash"
BANNER_MODEL="gemini-3.1-flash-image"
OPEN_AI_MODEL_ID="gpt-5.4"
CLAUDE_MODEL_ID="claude-sonnet-5"
AKIRA_MODEL_ID="claude-fable-5"

GCP_WORKLOAD_IDENTITY_TEMPLATE="gcp-workload-config-template.json"
GOOGLE_CLOUD_PROJECT=""
