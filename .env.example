# Akira ローカル実行用の環境変数サンプル
# 実際の値は .env にコピーして設定してください（.env は .gitignore 済み・コミット禁止）
# AWS_PROFILE や GitHub PAT などローカル専用の値はこのサンプルには含めていません。

# --- APIキー（Secrets Manager未使用のローカル開発用）---
GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
BRAVE_API_KEY=""

# --- AWSリソース識別子（ローカル開発では実環境の値を設定）---
AWS_REGION="us-east-1"
SECRET_ARN=""                        # Secrets Manager ARN（ローカルでAPIキーを直接設定する場合は不要）
LLM_DIST_ID=""                       # CloudFront Distribution ID（llm.okamomedia.tokyo 用）
REPORTS_DIST_ID=""                   # CloudFront Distribution ID（akira.okamomedia.tokyo 用）

# --- モデルID ---
BEDROCK_MODEL_ID=""
GEMINI_MODEL_ID="gemini-3.5-flash"
BANNER_MODEL="gemini-3.1-flash-image"
OPEN_AI_MODEL_ID="gpt-5.4"
CLAUDE_MODEL_ID="claude-sonnet-5"
AKIRA_MODEL_ID="claude-fable-5"

# --- 機能フラグ（本番相当の分析を行う場合は true に）---
ENABLE_GA4_MCP="true"                # GA4 analytics-mcp を有効化（Workload Identity 要設定）
ENABLE_BIGQUERY_MCP="true"           # BigQuery MCP を有効化（Search Console エクスポート用）

# --- GCP Workload Identity（GA4/BigQuery MCP 用）---
GCP_WORKLOAD_IDENTITY_TEMPLATE="gcp-workload-config-template.json"
GOOGLE_CLOUD_PROJECT=""
